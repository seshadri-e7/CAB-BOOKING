# Copy this file to .env and fill in your own values

PORT=5000

# MongoDB Atlas connection string (or local mongodb://localhost:27017/ucab)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ucab

# Secret used to sign JWT tokens - use a long random string in production
JWT_SECRET=replace_with_a_long_random_secret

# Client origin allowed for CORS
CLIENT_URL=http://localhost:3000
